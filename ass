import os, uuid
from pypdf import PdfReader
from azure.search.documents import SearchClient
from azure.search.documents.indexes import SearchIndexClient
from azure.search.documents.indexes.models import (
    SearchIndex, SearchFieldDataType, SimpleField, SearchableField, SearchField,
    VectorSearch, HnswAlgorithmConfiguration, VectorSearchProfile
)
from backend.config.settings import (
    SEARCH_ENDPOINT, EMBEDDING_MODEL, INDEX_REGLES, DOSSIER_PDFS,
    CHUNK_SIZE, CHUNK_OVERLAP, get_credential, get_openai_client
)

def index_existe(credential, index_name):
    try:
        SearchIndexClient(SEARCH_ENDPOINT, credential).get_index(index_name)
        return True
    except:
        return False

def get_embedding(openai_client, texte):
    return openai_client.embeddings.create(input=texte, model=EMBEDDING_MODEL).data[0].embedding

def chunker(texte, taille=CHUNK_SIZE, overlap=CHUNK_OVERLAP):
    mots, chunks, i = texte.split(), [], 0
    while i < len(mots):
        chunks.append(" ".join(mots[i:i+taille]))
        i += taille - overlap
    return chunks

def creer_index(credential, index_name):
    client = SearchIndexClient(SEARCH_ENDPOINT, credential)
    fields = [
        SimpleField(name="id",      type=SearchFieldDataType.String, key=True),
        SearchableField(name="contenu", type=SearchFieldDataType.String),
        SimpleField(name="fichier", type=SearchFieldDataType.String, filterable=True),
        SimpleField(name="page",    type=SearchFieldDataType.Int32,  filterable=True),
        SearchField(name="embedding", type=SearchFieldDataType.Collection(SearchFieldDataType.Single),
                    searchable=True, vector_search_dimensions=1536, vector_search_profile_name="profil"),
    ]
    vs = VectorSearch(
        algorithms=[HnswAlgorithmConfiguration(name="hnsw")],
        profiles=[VectorSearchProfile(name="profil", algorithm_configuration_name="hnsw")]
    )
    client.create_or_update_index(SearchIndex(name=index_name, fields=fields, vector_search=vs))
    print(f"Index '{index_name}' cree !")

def indexer_pdfs(credential, openai_client, dossier, index_name):
    if not os.path.exists(dossier):
        os.makedirs(dossier)
        print(f"Dossier '{dossier}' cree.")
        return 0, 0
    sc   = SearchClient(SEARCH_ENDPOINT, index_name, credential)
    docs = []
    pdfs = [f for f in os.listdir(dossier) if f.endswith(".pdf")]
    if not pdfs:
        print("Aucun PDF trouve.")
        return 0, 0
    for f in pdfs:
        print(f"Traitement : {f}")
        reader = PdfReader(f"{dossier}/{f}")
        for num, page in enumerate(reader.pages):
            texte = page.extract_text()
            if not texte: continue
            for chunk in chunker(texte):
                docs.append({"id": str(uuid.uuid4()), "contenu": chunk, "fichier": f,
                              "page": num+1, "embedding": get_embedding(openai_client, chunk)})
    sc.upload_documents(docs)
    print(f"{len(docs)} chunks indexes !")
    return len(docs), len(pdfs)

if __name__ == "__main__":
    cred = get_credential()
    oai  = get_openai_client()
    if index_existe(cred, INDEX_REGLES):
        print(f"Index '{INDEX_REGLES}' existe deja.")
