# ==============================================================================
# FICHIER : backend/utils/csv_handler.py
# ROLE    : Lecture des fichiers CSV et verification des clients
# ==============================================================================

import pandas as pd
from backend.config.settings import (
    CSV_APPLICANTS, CSV_VEHICLES, CSV_DRIVERS, CSV_LICENCE_VALIDATION
)

# ==============================================================================
# FONCTION : Login client — verification applicant_id + code postal
# ==============================================================================
def verifier_login(applicant_id: str, postal_code: str) -> dict:
    """
    Verifie les credentials du client.
    Retourne le profil client si valide, sinon None.
    """
    try:
        df = pd.read_csv(CSV_APPLICANTS)
        match = df[df["applicant_id"].astype(str) == str(applicant_id)]
        if match.empty:
            return {"success": False, "message": "Identifiant client introuvable."}
        client = match.iloc[0].to_dict()
        # Verification code postal
        csv_postal = str(client.get("postal_code", "")).replace(" ", "").upper()
        input_postal = str(postal_code).replace(" ", "").upper()
        if csv_postal != input_postal:
            return {"success": False, "message": "Code postal incorrect."}
        return {"success": True, "client": client}
    except Exception as e:
        return {"success": False, "message": f"Erreur : {str(e)}"}

# ==============================================================================
# FONCTION : Recuperer les vehicules d'un client
# ==============================================================================
def get_vehicules_client(applicant_id: str) -> list:
    try:
        df = pd.read_csv(CSV_VEHICLES)
        rows = df[df["applicant_id"].astype(str) == str(applicant_id)]
        return rows.to_dict("records")
    except Exception as e:
        print(f"Erreur lecture vehicules : {e}")
        return []

# ==============================================================================
# FONCTION : Recuperer les conducteurs additionnels d'un client
# ==============================================================================
def get_conducteurs_additionnels(applicant_id: str) -> list:
    try:
        df = pd.read_csv(CSV_DRIVERS)
        rows = df[df["applicant_id"].astype(str) == str(applicant_id)]
        return rows.to_dict("records")
    except Exception as e:
        print(f"Erreur lecture conducteurs : {e}")
        return []

# ==============================================================================
# FONCTION : Recuperer un client par applicant_id
# ==============================================================================
def get_client(applicant_id: str) -> dict:
    try:
        df = pd.read_csv(CSV_APPLICANTS)
        match = df[df["applicant_id"].astype(str) == str(applicant_id)]
        if not match.empty:
            return match.iloc[0].to_dict()
    except Exception as e:
        print(f"Erreur lecture client : {e}")
    return {}

# ==============================================================================
# FONCTION : Valider le permis d'un client
# ==============================================================================
def valider_permis(applicant_id: str) -> dict:
    try:
        df = pd.read_csv(CSV_LICENCE_VALIDATION)
        match = df[df["applicant_id"].astype(str) == str(applicant_id)]
        if not match.empty:
            row = match.iloc[0]
            return {
                "is_valid"         : bool(row.get("is_valid_licence", False)),
                "validation_status": str(row.get("validation_status", "")),
                "licence_class"    : str(row.get("licence_class", "")),
                "years_licenced"   : int(row.get("years_licenced", 0) or 0),
