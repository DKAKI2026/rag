async def _pipeline_evaluation(
    applicant       : dict,
    vehicle         : dict,
    on_progress     : Callable[[str], None] | None = None,
) -> dict:
    """
    Pipeline complet d'évaluation d'une demande d'assurance.

    Paramètres :
      applicant    : dict du conducteur principal (depuis CSV ou formulaire)
      vehicle      : dict du véhicule sélectionné
      on_progress  : callback optionnel appelé à chaque étape (pour Streamlit)

    Retourne un dict final avec :
      - statut         : REFUSE | VERIFICATION_HUMAINE | APPROUVE
      - score          : int
      - evaluation     : dict (sortie decisions.py)
      - tarification   : dict (sortie agent_tarification) ou None
      - explication    : str (sortie GPT pour le client)
      - demande_id     : str
      - pipeline_log   : list[dict] (log de chaque étape)
      - duree_totale_ms: int
    """
    t_start    = time.time()
    pipeline_log = []

    def _progress(msg: str):
        if on_progress:
            on_progress(msg)

    agent_tarification_vmr, agent_evaluer_demande, _, _ = _import_agents()

    # ──────────────────────────────────────────────────────────────────────────
    # ÉTAPE 1 — Récupération conducteurs additionnels + validation permis
    # ──────────────────────────────────────────────────────────────────────────
    _progress("🔍 Étape 1/5 — Récupération des données complémentaires…")
    t0 = time.time()

    applicant_id       = str(applicant.get("applicant_id", ""))
    additional_drivers = get_conducteurs_additionnels(applicant_id)
    licence_check      = valider_licence(applicant_id)

    pipeline_log.append(_etape(
        "recuperation_donnees", "ok",
        {
            "nb_conducteurs_additionnels": len(additional_drivers),
            "licence_valide"             : licence_check.get("is_valid", True),
            "licence_statut"             : licence_check.get("validation_status", "non_verifie"),
        },
        duree_ms=int((time.time() - t0) * 1000),
    ))

    # ──────────────────────────────────────────────────────────────────────────
    # ÉTAPE 2 — Évaluation règles métier (synchrone, rapide)
    # ──────────────────────────────────────────────────────────────────────────
    _progress("⚙️ Étape 2/5 — Évaluation des règles métier…")
    t0 = time.time()

    evaluation = evaluer_demande(applicant, vehicle, additional_drivers)
    statut     = evaluation["statut"]
    score      = evaluation["score"]
    triggers   = evaluation.get("triggers", [])

    # Profil conducteur depuis le score result (déjà calculé dans decisions.py)
    from backend.rules.scoring import get_driver_profile
    profil = get_driver_profile(
        int(applicant.get("years_licenced", 0) or 0),
        str(applicant.get("licence_class", "G") or "G"),
    )

    pipeline_log.append(_etape(
        "evaluation_regles_metier", "ok",
        {
            "statut"  : statut,
            "score"   : score,
            "profil"  : profil,
            "triggers": [t["code"] for t in triggers],
            "raisons" : evaluation.get("raisons", []),
        },
        duree_ms=int((time.time() - t0) * 1000),
    ))

    # ──────────────────────────────────────────────────────────────────────────
    # ÉTAPE 3 — Tarification VMR (seulement si non-refus)
    # ──────────────────────────────────────────────────────────────────────────
    tarification = None

    if statut != "REFUSE":
        _progress("💰 Étape 3/5 — Calcul de la tarification VMR (RAG + GPT)…")
        t0 = time.time()
        try:
            tarification = await agent_tarification_vmr(
                applicant         = applicant,
                vehicle           = vehicle,
                score_risque      = score,
                profil_conducteur = profil,
                triggers          = triggers,
            )
            pipeline_log.append(_etape(
                "tarification_vmr", "ok",
                {
                    "groupe_vmr"    : tarification["groupe_vmr"],
                    "source_vmr"    : tarification["source_vmr"],
                    "prime_annuelle": tarification.get("prime_annuelle"),
                    "prime_mensuelle": tarification.get("prime_mensuelle"),
                    "specialisee"   : tarification.get("necessite_souscription_specialisee"),
                },
                duree_ms=int((time.time() - t0) * 1000),
            ))
            # Injecter la tarification VMR dans l'évaluation (remplace l'ancienne estimation)
            evaluation["estimation"] = {
                "prime_annuelle"  : tarification.get("prime_annuelle"),
                "prime_mensuelle" : tarification.get("prime_mensuelle"),
                "score_risque"    : score,
                "profil"          : profil,
                "groupe_vmr"      : tarification["groupe_vmr"],
                "source_vmr"      : tarification["source_vmr"],
                "fourchette_basse": tarification.get("fourchette_basse"),
                "fourchette_haute": tarification.get("fourchette_haute"),
            }
        except Exception as e:
            pipeline_log.append(_etape(
                "tarification_vmr", "erreur",
                {"erreur": str(e)},
                duree_ms=int((time.time() - t0) * 1000),
            ))
            # Fallback : conserver l'estimation basique de decisions.py
            tarification = evaluation.get("estimation")
    else:
        pipeline_log.append(_etape("tarification_vmr", "skip", {"raison": "Dossier refusé — tarification non calculée"}))

    # ──────────────────────────────────────────────────────────────────────────
    # ÉTAPE 4 — Génération de l'explication client (GPT)
    # ──────────────────────────────────────────────────────────────────────────
    _progress("💬 Étape 4/5 — Génération de l'explication client…")
    t0 = time.time()

    openai_client = get_openai_client()
    est           = evaluation.get("estimation") or {}
    details_str   = "\n".join(evaluation.get("details", []))
    triggers_str  = "\n".join([t["description"] for t in triggers])
    note_vmr      = ""
    if tarification and isinstance(tarification, dict):
        note_vmr = f"\nGroupe VMR : {tarification.get('groupe_vmr','N/A')} ({tarification.get('source_vmr','')}) — {tarification.get('justification_vmr','')}"
        if tarification.get("necessite_souscription_specialisee"):
            note_vmr += "\n⚠️ Ce véhicule nécessite une souscription spécialisée."

    prompt_explication = f"""Tu es un agent d'assurance automobile de Desjardins.
Explique au client le résultat de son évaluation de façon claire et professionnelle en français.

Statut          : {statut}
Score de risque : {score}/12
Détails calcul  : {details_str}
Triggers        : {triggers_str or 'aucun'}{note_vmr}
Prime estimée   : {est.get('prime_annuelle', 'N/A')} $/an  ({est.get('prime_mensuelle','N/A')} $/mois)
Fourchette      : {est.get('fourchette_basse','N/A')} $ – {est.get('fourchette_haute','N/A')} $

Règles de ton message :
- Si REFUSE : explique pourquoi sans être brutal, exprime de la compassion
- Si VERIFICATION_HUMAINE : explique que le dossier est en traitement humain (1-3 jours)
- Si APPROUVE : félicite et présente la prime clairement
- Mentionne le groupe VMR et ce qu'il signifie si disponible
- Sois concis (max 180 mots), professionnel et humain
"""

    resp_expl = openai_client.chat.completions.create(
        model     = AZURE_OPENAI_DEPLOYMENT,
        messages  = [{"role": "user", "content": prompt_explication}],
        max_tokens= 350,
        temperature=0.4,
    )
    explication_client = resp_expl.choices[0].message.content

    pipeline_log.append(_etape(
        "explication_client", "ok",
        {"nb_tokens": resp_expl.usage.total_tokens},
        duree_ms=int((time.time() - t0) * 1000),
    ))

    # ──────────────────────────────────────────────────────────────────────────
    # ÉTAPE 5 — Sauvegarde Excel
    # ──────────────────────────────────────────────────────────────────────────
    _progress("💾 Étape 5/5 — Sauvegarde de la demande…")
    t0 = time.time()

    demande_id = creer_demande(applicant, vehicle, evaluation)
    evaluation["demande_id"]          = demande_id
    evaluation["explication_client"]  = explication_client

    pipeline_log.append(_etape(
        "sauvegarde_excel", "ok",
        {"demande_id": demande_id},
        duree_ms=int((time.time() - t0) * 1000),
    ))

    duree_totale_ms = int((time.time() - t_start) * 1000)
    _progress(f"✅ Pipeline terminé en {duree_totale_ms / 1000:.1f}s")

    return {
        "statut"           : statut,
        "score"            : score,
        "profil"           : profil,
        "evaluation"       : evaluation,
        "tarification"     : tarification,
        "explication_client": explication_client,
        "demande_id"       : demande_id,
        "pipeline_log"     : pipeline_log,
        "duree_totale_ms"  : duree_totale_ms,
    }


