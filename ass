def init_fichier():
    os.makedirs(DEMANDES_FOLDER, exist_ok=True)
    if not os.path.exists(DEMANDES_FILE):
        df = pd.DataFrame(columns=COLONNES)
        df.to_excel(DEMANDES_FILE, index=False)

# ==============================================================================
# FONCTION : Creer une nouvelle demande
# ==============================================================================
def creer_demande(applicant: dict, vehicle: dict, evaluation: dict) -> str:
    """
    Cree une nouvelle demande dans le fichier Excel.
    Retourne le demande_id genere.
    """
    init_fichier()
    df = pd.read_excel(DEMANDES_FILE)

    # Generer un ID unique
    demande_id = f"DEM-{datetime.now().strftime('%Y%m%d%H%M%S')}-{applicant.get('applicant_id','')}"

    estimation = evaluation.get("estimation") or {}
    triggers   = "; ".join([t["description"] for t in evaluation.get("triggers", [])])
    raisons    = "; ".join(evaluation.get("raisons", []))

    nouvelle = {
        "demande_id"         : demande_id,
        "applicant_id"       : applicant.get("applicant_id", ""),
        "first_name"         : applicant.get("first_name", ""),
        "last_name"          : applicant.get("last_name", ""),
        "email"              : applicant.get("email", ""),
        "phone"              : applicant.get("phone", ""),
        "vehicle_make"       : vehicle.get("make", ""),
        "vehicle_model"      : vehicle.get("model", ""),
        "vehicle_year"       : vehicle.get("year", ""),
        "vehicle_vin"        : vehicle.get("vin", ""),
        "vehicle_value"      : vehicle.get("vehicle_value", ""),
        "score_risque"       : evaluation.get("score", 0),
        "profil_conducteur"  : estimation.get("profil", ""),
        "statut"             : evaluation.get("statut", ""),
        "triggers"           : triggers,
        "raisons_refus"      : raisons,
        "prime_annuelle"     : estimation.get("prime_annuelle", ""),
        "prime_mensuelle"    : estimation.get("prime_mensuelle", ""),
        "date_demande"       : datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "date_decision"      : "",
        "employe_decision"   : "",
        "commentaire_employe": "",
    }

    df = pd.concat([df, pd.DataFrame([nouvelle])], ignore_index=True)
    df.to_excel(DEMANDES_FILE, index=False)
    return demande_id

# ==============================================================================
# FONCTION : Lire toutes les demandes
# ==============================================================================
def lire_demandes() -> pd.DataFrame:
    init_fichier()
    return pd.read_excel(DEMANDES_FILE)

# ==============================================================================
