def lire_demandes_client(applicant_id: str) -> list:
    df = lire_demandes()
    rows = df[df["applicant_id"].astype(str) == str(applicant_id)]
    return rows.to_dict("records")

# ==============================================================================
# FONCTION : Mettre a jour le statut d'une demande (par employe)
# ==============================================================================
def mettre_a_jour_statut(demande_id: str, statut: str, employe: str, commentaire: str = "") -> bool:
    try:
        init_fichier()
        df = pd.read_excel(DEMANDES_FILE)
        mask = df["demande_id"].astype(str) == str(demande_id)
        if mask.sum() == 0:
            return False
        df.loc[mask, "statut"]              = statut
        df.loc[mask, "employe_decision"]    = employe
        df.loc[mask, "commentaire_employe"] = commentaire
        df.loc[mask, "date_decision"]       = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        df.to_excel(DEMANDES_FILE, index=False)
        return True
    except Exception as e:
        print(f"Erreur MAJ statut : {e}")
        return False

# ==============================================================================
# FONCTION : Statistiques pour employe / developpeur
# ==============================================================================
def get_stats() -> dict:
    df = lire_demandes()
    if df.empty:
        return {"total": 0, "approuve": 0, "refuse": 0, "en_attente": 0}
    return {
        "total"     : len(df),
        "approuve"  : len(df[df["statut"] == "APPROUVE"]),
        "refuse"    : len(df[df["statut"] == "REFUSE"]),
        "en_attente": len(df[df["statut"] == "VERIFICATION_HUMAINE"]),
    }

