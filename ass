# ==============================================================================
# FICHIER : backend/rules/scoring.py
# ROLE    : Calcul du score de risque selon les regles Desjardins
# SOURCE  : Images fournies - Driver profiles + Point values
# ==============================================================================

# ==============================================================================
# SECTION 1 : PROFILS CONDUCTEUR
# Profile 1 → licensed >= 15 ans
# Profile 2 → licensed 4 a < 15 ans
# Profile 3 → licensed < 4 ans OU G1/G2
# ==============================================================================
def get_driver_profile(years_licenced: int, licence_class: str) -> int:
    if licence_class in ["G1", "G2"]:
        return 3
    if years_licenced >= 15:
        return 1
    if years_licenced >= 4:
        return 2
    return 3

# ==============================================================================
# SECTION 2 : TABLE DE POINTS PAR PROFIL
# ==============================================================================
POINTS = {
    "minor_1st"              : {1: 2,  2: 2,  3: 4},
    "minor_additional"       : {1: 4,  2: 5,  3: 6},
    "major_each"             : {1: 12, 2: 16, 3: 16},
    "careless_driving"       : {1: 15, 2: 16, 3: 16},
    "serious_criminal"       : {1: 16, 2: 16, 3: 16},
    "chargeable_acc_3yr"     : {1: 6,  2: 7,  3: 8},
    "chargeable_acc_3_6yr"   : {1: 6,  2: 6,  3: 8},
    "nonpayment_cancel_1st"  : {1: 4,  2: 4,  3: 4},
    "nonpayment_cancel_addl" : {1: 6,  2: 6,  3: 6},
}

# ==============================================================================
# SECTION 3 : SEUIL
# Score >= 12 → declined_referred_gaa
# ==============================================================================
SCORE_THRESHOLD = 12

# ==============================================================================
# SECTION 4 : CALCUL DU SCORE POUR UN CONDUCTEUR
# ==============================================================================
def calculer_score_conducteur(row: dict, profile: int, is_principal: bool = True) -> dict:
    """
    Calcule le score de risque pour un conducteur.
    row : dict avec les colonnes du CSV applicants ou additional_drivers
    profile : 1, 2 ou 3
    is_principal : True = conducteur principal (annulation non-paiement compte)
    """
    score   = 0
    details = []

    p = profile

    # Infractions mineures
    minor = int(row.get("minor_convictions_3yr", 0) or 0)
    if minor >= 1:
        pts = POINTS["minor_1st"][p]
        score += pts
        details.append(f"Infraction mineure 1re: +{pts}")
    if minor > 1:
        pts = POINTS["minor_additional"][p] * (minor - 1)
        score += pts
        details.append(f"Infractions mineures additionnelles ({minor-1}): +{pts}")

    # Infractions majeures
    major = int(row.get("major_convictions_3yr", 0) or 0)
    if major > 0:
        pts = POINTS["major_each"][p] * major
        score += pts
        details.append(f"Infractions majeures ({major}): +{pts}")

    # Infractions graves / criminelles
    serious = int(row.get("serious_convictions_3yr", 0) or 0)
    if serious > 0:
        pts = POINTS["serious_criminal"][p] * serious
        score += pts
        details.append(f"Infractions graves ({serious}): +{pts}")

    # Accidents responsables 3 ans
    acc_3yr = int(row.get("at_fault_accidents_3yr", 0) or 0)
    if acc_3yr > 0:
        pts = POINTS["chargeable_acc_3yr"][p] * acc_3yr
        score += pts
        details.append(f"Accidents responsables 3 ans ({acc_3yr}): +{pts}")

    # Accidents responsables 3-6 ans
    acc_6yr = int(row.get("at_fault_accidents_6yr", 0) or 0)
    if acc_6yr > 0:
        pts = POINTS["chargeable_acc_3_6yr"][p] * acc_6yr
        score += pts
        details.append(f"Accidents responsables 3-6 ans ({acc_6yr}): +{pts}")

    # Annulation non-paiement (principal seulement)
    if is_principal:
        cancel = int(row.get("nonpayment_cancellations_3yr", 0) or 0)
        if cancel >= 1:
            pts = POINTS["nonpayment_cancel_1st"][p]
            score += pts
            details.append(f"Annulation non-paiement 1re: +{pts}")
        if cancel > 1:
            pts = POINTS["nonpayment_cancel_addl"][p] * (cancel - 1)
            score += pts
            details.append(f"Annulations non-paiement additionnelles ({cancel-1}): +{pts}")

    return {"score": score, "profile": p, "details": details}

# ==============================================================================
# SECTION 5 : SCORE TOTAL (principal + conducteurs additionnels)
# Note : conducteurs avec is_excluded=True ne comptent pas
# ==============================================================================
def calculer_score_total(applicant: dict, additional_drivers: list) -> dict:
    """
    Calcule le score total de la demande.
    applicant : dict du conducteur principal
    additional_drivers : liste de dicts des conducteurs additionnels
    """
    profile = get_driver_profile(
        int(applicant.get("years_licenced", 0) or 0),
        str(applicant.get("licence_class", "G") or "G")
    )

    result_principal = calculer_score_conducteur(applicant, profile, is_principal=True)
    score_total      = result_principal["score"]
    tous_details     = [f"[Principal - Profile {profile}]"] + result_principal["details"]

    for driver in additional_drivers:
        # Conducteurs exclus (OPCF 28A) ne comptent pas
        if str(driver.get("is_excluded", False)).lower() in ["true", "1", "yes"]:
            tous_details.append(f"[{driver.get('first_name','')} - EXCLU - 0 pts]")
            continue

        d_profile = get_driver_profile(
            int(driver.get("years_licenced", 0) or 0),
            str(driver.get("licence_class", "G") or "G")
        )
        d_result = calculer_score_conducteur(driver, d_profile, is_principal=False)
        score_total += d_result["score"]
        tous_details.append(f"[{driver.get('first_name','')} - Profile {d_profile}: +{d_result['score']}]")
        tous_details.extend(d_result["details"])

    return {
        "score_total"     : score_total,
        "profile_principal": profile,
        "details"         : tous_details,
        "depasse_seuil"   : score_total >= SCORE_THRESHOLD,
    }

