# ==============================================================================
# FICHIER : backend/agents/agent_tarification.py
# ROLE    : Agent de tarification basé sur la logique VMR (vmr_vehicle_rating_fr)
#           et les règles des PDFs indexés dans Azure AI Search.
#           NE contient AUCUNE formule codée en dur — tout passe par le RAG + GPT.
# ==============================================================================

import asyncio
import concurrent.futures
from azure.search.documents import SearchClient
from backend.config.settings import (
    SEARCH_ENDPOINT, INDEX_REGLES, EMBEDDING_MODEL,
    AZURE_OPENAI_DEPLOYMENT, TOP_K_RESULTS,
    get_credential, get_openai_client
)

# ==============================================================================
# SECTION 1 : HELPERS RAG (réutilisés localement pour éviter import cyclique)
# ==============================================================================

def _get_embedding(openai_client, texte: str) -> list:
    return openai_client.embeddings.create(
        input=texte, model=EMBEDDING_MODEL
    ).data[0].embedding


def _recherche_rag(credential, openai_client, question: str, top_k: int = None) -> list:
    """Recherche vectorielle + full-text dans l'index Azure AI Search."""
    try:
        k = top_k or TOP_K_RESULTS
        q_emb = _get_embedding(openai_client, question)
        client = SearchClient(SEARCH_ENDPOINT, INDEX_REGLES, credential)
        resultats = list(client.search(
            search_text=question,
            vector_queries=[{
                "vector": q_emb,
                "fields": "embedding",
                "k": k,
                "kind": "vector"
            }]
        ))
        return [
            {
                "contenu": r["contenu"],
                "fichier": r["fichier"],
                "page"   : r["page"],
            }
            for r in resultats
        ]
    except Exception as e:
        print(f"[agent_tarification] Erreur RAG : {e}")
        return []


# ==============================================================================
# SECTION 2 : DÉTERMINATION DU GROUPE VMR via RAG + GPT
# ==============================================================================

async def _determiner_groupe_vmr(
    openai_client,
    credential,
    make: str,
    model: str,
    year: int,
    vehicle_value: float,
    is_modified: bool,
    is_antique: bool,
    is_kit_car: bool,
) -> dict:
    """
    Utilise le RAG sur vmr_vehicle_rating_fr pour déterminer le groupe
    de tarification (1-99) du véhicule.

    Retourne :
      groupe        : int (1-99)
      source        : "vmr_table" | "valeur_repli" | "groupe_99_reference"
      justification : str
      contexte_rag  : list[dict]  (chunks retrouvés)
    """
    query_vmr = (
        f"groupe tarification VMR {make} {model} {year} "
        f"échelle groupes véhicule assurance"
    )
    chunks = _recherche_rag(credential, openai_client, query_vmr, top_k=6)

    contexte = "\n\n".join([
        f"[{c['fichier']} p.{c['page']}]\n{c['contenu']}"
        for c in chunks
    ]) if chunks else "Aucun document VMR trouvé."

    flags = []
    if is_modified : flags.append("véhicule modifié")
    if is_antique  : flags.append("véhicule antique")
    if is_kit_car  : flags.append("kit car")
    flags_str = ", ".join(flags) if flags else "aucun"

    prompt = f"""Tu es un souscripteur senior chez Desjardins spécialisé en tarification VMR.

## Documents de référence (extraits des PDFs internes) :
{contexte}

## Véhicule à évaluer :
- Marque      : {make}
- Modèle      : {model}
- Année       : {year}
- Valeur      : {vehicle_value:,.0f} $
- Particularités : {flags_str}

## Ta tâche :
En te basant UNIQUEMENT sur les documents fournis :

1. Détermine le groupe de tarification VMR (entier de 1 à 99) le plus approprié
   pour ce véhicule selon l'échelle décrite dans les PDFs.

2. Si le véhicule n'apparaît pas dans la table VMR (année trop récente,
   importation rare, kit car, antique, modifié), retourne le groupe 99
   et indique que c'est une référence à la souscription.

3. Si le VMR est indisponible, applique la tarification selon la valeur
   (table de repli du document) et indique la base annuelle Chapitre B correspondante.

Réponds UNIQUEMENT en JSON valide, sans markdown ni backticks :
{{
  "groupe_vmr"    : <entier 1-99>,
  "source"        : "<vmr_table | valeur_repli | groupe_99_reference>",
  "base_annuelle_repli" : <montant en dollars ou null si non applicable>,
  "justification" : "<explication courte en français, max 3 phrases>"
}}
"""

    response = openai_client.chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[{"role": "user", "content": prompt}],
        max_tokens=400,
        temperature=0.1,
    )

    raw = response.choices[0].message.content.strip()
    raw = raw.replace("```json", "").replace("```", "").strip()
    j = raw.find("{"); e = raw.rfind("}") + 1

    import json
    try:
        vmr_result = json.loads(raw[j:e])
    except Exception:
        vmr_result = {
            "groupe_vmr"          : 99,
            "source"              : "groupe_99_reference",
            "base_annuelle_repli" : None,
            "justification"       : "Impossible de déterminer le groupe VMR automatiquement.",
        }

    vmr_result["contexte_rag"] = chunks
    return vmr_result


# ==============================================================================
# SECTION 3 : CALCUL DE LA PRIME via RAG + GPT
# ==============================================================================

async def _calculer_prime_vmr(
    openai_client,
    credential,
    applicant : dict,
    vehicle   : dict,
    groupe_vmr: int,
    source_vmr: str,
    base_repli: float | None,
    score_risque      : int,
    profil_conducteur : int,
    triggers          : list,
) -> dict:
    """
    Demande à GPT de calculer la prime en se basant sur :
    - Le groupe VMR déterminé
    - Les règles des PDFs (RAG)
    - Le profil conducteur et le score de risque
    - Les rabais applicables
    """
    query_prime = (
        f"calcul prime assurance automobile groupe VMR {groupe_vmr} "
        f"facteurs ajustement rabais profil conducteur score risque"
    )
    chunks_prime = _recherche_rag(credential, openai_client, query_prime, top_k=6)

    contexte_prime = "\n\n".join([
        f"[{c['fichier']} p.{c['page']}]\n{c['contenu']}"
        for c in chunks_prime
    ]) if chunks_prime else "Aucun document de tarification trouvé."

    rabais = []
    if str(vehicle.get("has_winter_tires","")).lower()   in ["true","1","yes"]: rabais.append("pneus hiver")
    if str(vehicle.get("has_anti_theft","")).lower()      in ["true","1","yes"]: rabais.append("antivol")
    if str(vehicle.get("has_tracking_system","")).lower() in ["true","1","yes"]: rabais.append("système de repérage")
    if str(applicant.get("completed_driving_course","")).lower() in ["true","1","yes"]: rabais.append("cours de conduite")
    if str(applicant.get("is_existing_desjardins_member","")).lower() in ["true","1","yes"]: rabais.append("membre Desjardins existant")
    if str(applicant.get("has_home_insurance","")).lower() in ["true","1","yes"]: rabais.append("assurance habitation Desjardins")

    triggers_str = "; ".join([t["description"] for t in triggers]) if triggers else "aucun"
    rabais_str   = ", ".join(rabais) if rabais else "aucun"

    note_repli = ""
    if source_vmr == "valeur_repli" and base_repli:
        note_repli = f"\n⚠️ VMR indisponible — base annuelle Chapitre B (repli) : {base_repli:,.0f} $"
    elif source_vmr == "groupe_99_reference":
        note_repli = "\n⚠️ Groupe 99 — référence obligatoire à la souscription spécialisée."

    prompt = f"""Tu es un actuaire senior chez Desjardins Assurances.

## Documents de référence (extraits des PDFs internes) :
{contexte_prime}

## Données du dossier :
- Groupe VMR          : {groupe_vmr} / 99  (source : {source_vmr}){note_repli}
- Profil conducteur   : {profil_conducteur} (1=expérimenté ≥15 ans, 2=intermédiaire 4-15 ans, 3=novice <4 ans ou G1/G2)
- Score de risque     : {score_risque} / 12
- Valeur du véhicule  : {float(vehicle.get('vehicle_value', 0) or 0):,.0f} $
- Âge du véhicule     : {vehicle.get('vehicle_age', 'N/A')} ans
- Usage annuel (km)   : {vehicle.get('annual_km', 'N/A')}
- Financement/Leasing : financement={vehicle.get('is_financed','N/A')}, leasing={vehicle.get('is_leased','N/A')}
- Rabais applicables  : {rabais_str}
- Triggers détectés   : {triggers_str}
- Province            : {applicant.get('province','QC')}

## Ta tâche :
En te basant UNIQUEMENT sur les règles des documents fournis et le groupe VMR ci-dessus :

1. Calcule une estimation de prime annuelle réaliste pour ce profil.
2. Applique les rabais et majorations pertinents selon les PDFs.
3. Si groupe 99 ou source=groupe_99_reference : indique que la prime
   exacte nécessite une souscription spécialisée, mais fournis quand même
   une fourchette indicative basée sur la valeur du véhicule.
4. Détaille chaque composante du calcul.

Réponds UNIQUEMENT en JSON valide, sans markdown ni backticks :
{{
  "prime_annuelle_estimee"  : <montant numérique>,
  "prime_mensuelle_estimee" : <montant numérique>,
  "fourchette_basse"        : <montant numérique>,
  "fourchette_haute"        : <montant numérique>,
  "necessite_souscription_specialisee" : <true|false>,
  "composantes": [
    {{"label": "<nom>", "montant": <valeur>, "type": "<base|majoration|rabais>"}}
  ],
  "note_client" : "<message clair pour le client, max 2 phrases, en français>"
}}
"""

    response = openai_client.chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[{"role": "user", "content": prompt}],
        max_tokens=600,
        temperature=0.1,
    )

    raw = response.choices[0].message.content.strip()
    raw = raw.replace("```json", "").replace("```", "").strip()
    j = raw.find("{"); e = raw.rfind("}") + 1

    import json
    try:
        prime_result = json.loads(raw[j:e])
    except Exception:
        prime_result = {
            "prime_annuelle_estimee"             : None,
            "prime_mensuelle_estimee"            : None,
            "fourchette_basse"                   : None,
            "fourchette_haute"                   : None,
            "necessite_souscription_specialisee" : True,
            "composantes"                        : [],
            "note_client"                        : "Estimation indisponible — dossier référé à la souscription.",
        }

    prime_result["contexte_rag"] = chunks_prime
    return prime_result


# ==============================================================================
# SECTION 4 : AGENT PRINCIPAL (async)
# ==============================================================================

async def agent_tarification_vmr(
    applicant        : dict,
    vehicle          : dict,
    score_risque     : int,
    profil_conducteur: int,
    triggers         : list,
) -> dict:
    """
    Agent principal de tarification VMR.

    Étapes :
      1. Détermine le groupe VMR via RAG + GPT
      2. Calcule la prime via RAG + GPT en utilisant ce groupe
      3. Retourne un dict complet avec estimation, groupe, justification

    Retourne :
      groupe_vmr        : int
      source_vmr        : str
      justification_vmr : str
      prime_annuelle    : float | None
      prime_mensuelle   : float | None
      fourchette_basse  : float | None
      fourchette_haute  : float | None
      composantes       : list
      note_client       : str
      necessite_souscription_specialisee : bool
    """
    credential    = get_credential()
    openai_client = get_openai_client()

    make          = str(vehicle.get("make", ""))
    model         = str(vehicle.get("model", ""))
    year          = int(vehicle.get("year", 0) or 0)
    vehicle_value = float(vehicle.get("vehicle_value", 0) or 0)
    is_modified   = str(vehicle.get("is_modified", "")).lower()  in ["true","1","yes"]
    is_antique    = str(vehicle.get("is_antique",  "")).lower()  in ["true","1","yes"]
    is_kit_car    = str(vehicle.get("is_kit_car",  "")).lower()  in ["true","1","yes"]

    # ÉTAPE 1 — Groupe VMR
    vmr = await _determiner_groupe_vmr(
        openai_client, credential,
        make, model, year, vehicle_value,
        is_modified, is_antique, is_kit_car,
    )

    # ÉTAPE 2 — Prime
    prime = await _calculer_prime_vmr(
        openai_client, credential,
        applicant, vehicle,
        groupe_vmr        = vmr["groupe_vmr"],
        source_vmr        = vmr["source"],
        base_repli        = vmr.get("base_annuelle_repli"),
        score_risque      = score_risque,
        profil_conducteur = profil_conducteur,
        triggers          = triggers,
    )

    return {
        "groupe_vmr"               : vmr["groupe_vmr"],
        "source_vmr"               : vmr["source"],
        "justification_vmr"        : vmr["justification"],
        "base_annuelle_repli"      : vmr.get("base_annuelle_repli"),
        "prime_annuelle"           : prime.get("prime_annuelle_estimee"),
        "prime_mensuelle"          : prime.get("prime_mensuelle_estimee"),
        "fourchette_basse"         : prime.get("fourchette_basse"),
        "fourchette_haute"         : prime.get("fourchette_haute"),
        "composantes"              : prime.get("composantes", []),
        "note_client"              : prime.get("note_client", ""),
        "necessite_souscription_specialisee": prime.get("necessite_souscription_specialisee", False),
        "_rag_vmr"                 : vmr.get("contexte_rag", []),
        "_rag_prime"               : prime.get("contexte_rag", []),
    }


# ==============================================================================
# SECTION 5 : WRAPPER SYNCHRONE pour Streamlit
# ==============================================================================

def tarification_vmr_sync(
    applicant        : dict,
    vehicle          : dict,
    score_risque     : int,
    profil_conducteur: int,
    triggers         : list,
) -> dict:
    """Wrapper synchrone appelable depuis Streamlit ou l'orchestrateur."""
    def run():
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        try:
            return loop.run_until_complete(
                agent_tarification_vmr(
                    applicant, vehicle,
                    score_risque, profil_conducteur, triggers,
                )
            )
        finally:
            loop.close()

    with concurrent.futures.ThreadPoolExecutor(max_workers=1) as ex:
        return ex.submit(run).result(timeout=120)


