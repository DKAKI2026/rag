    "raisons_refus",    # raisons de refus
    "prime_annuelle", "prime_mensuelle",
    "date_demande", "date_decision", "employe_decision", "commentaire_employe",
]

# ==============================================================================
# FONCTION : Initialiser le fichier Excel s'il n'existe pas
