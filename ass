import asyncio
import concurrent.futures
from azure.search.documents import SearchClient
from backend.config.settings import (
    SEARCH_ENDPOINT, INDEX_REGLES, EMBEDDING_MODEL,
    AZURE_OPENAI_DEPLOYMENT, TOP_K_RESULTS,
    get_credential, get_openai_client
)

# ==============================================================================
# FONCTION : Embedding
# ==============================================================================
def get_embedding(openai_client, texte: str) -> list:
    return openai_client.embeddings.create(
        input=texte, model=EMBEDDING_MODEL
    ).data[0].embedding

# ==============================================================================
# FONCTION : Recherche RAG
# ==============================================================================
def recherche_rag(credential, openai_client, question: str) -> list:
    try:
        q_emb = get_embedding(openai_client, question)
        client = SearchClient(SEARCH_ENDPOINT, INDEX_REGLES, credential)
        resultats = list(client.search(
            search_text=question,
            vector_queries=[{"vector": q_emb, "fields": "embedding", "k": TOP_K_RESULTS, "kind": "vector"}]
        ))
        return [{"contenu": r["contenu"], "fichier": r["fichier"], "page": r["page"]} for r in resultats]
    except Exception as e:
        print(f"Erreur RAG : {e}")
        return []

# ==============================================================================
# AGENT : Chatbot regles assurance (async)
# ==============================================================================
async def agent_chatbot_assurance(question: str, historique: list = None) -> dict:
    """Repond aux questions sur les regles d'assurance automobile"""
    credential    = get_credential()
    openai_client = get_openai_client()

    resultats = recherche_rag(credential, openai_client, question)

    contexte = "\n\n".join([
        f"[{r['fichier']} p.{r['page']}]\n{r['contenu']}"
        for r in resultats
    ]) if resultats else "Aucun document trouve."

    messages = [
        {"role": "system", "content": """
        Tu es un assistant specialise en assurance automobile pour Desjardins.
        Tu reponds aux questions des clients sur les regles d'assurance.
        - Reponds en francais
        - Sois clair et professionnel
        - Base-toi UNIQUEMENT sur les documents fournis
        - Si tu ne sais pas, dis-le clairement
        - Ne donne jamais de conseil juridique ou financier definitif
        """},
        {"role": "user", "content": f"Documents:\n{contexte}\n\nQuestion: {question}"}
    ]

    if historique:
        for h in historique[-4:]:
            messages.insert(-1, {"role": h["role"], "content": h["content"]})

    response = openai_client.chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=messages,
        max_tokens=600,
        temperature=0.3,
    )

    return {
        "reponse": response.choices[0].message.content,
        "sources": resultats,
        "tokens" : response.usage.total_tokens,
    }

# ==============================================================================
# WRAPPER SYNCHRONE pour Streamlit
# ==============================================================================
def chatbot_assurance(question: str, historique: list = None) -> dict:
    def run():
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        try:
            return loop.run_until_complete(agent_chatbot_assurance(question, historique))
        finally:
            loop.close()

    with concurrent.futures.ThreadPoolExecutor(max_workers=1) as ex:
        return ex.submit(run).result(timeout=60)

