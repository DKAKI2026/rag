import pandas as pd
from backend.config.settings import CSV_VIN_BLACKLIST

# ==============================================================================
# SECTION 1 : VERIFICATION VIN BLACKLIST
# ==============================================================================
def verifier_vin_blacklist(vin: str) -> dict:
    """Verifie si un VIN est dans la liste noire"""
    try:
        df = pd.read_csv(CSV_VIN_BLACKLIST)
        match = df[df["vin"].astype(str).str.upper() == str(vin).upper()]
        if not match.empty:
            return {
                "blacklisted": True,
                "reason"     : match.iloc[0].get("reason", "VIN blackliste"),
                "added_date" : str(match.iloc[0].get("added_date", "")),
            }
    except Exception as e:
        print(f"Erreur lecture blacklist : {e}")
    return {"blacklisted": False}

# ==============================================================================
# SECTION 2 : REGLES DE REFUS DIRECT
# Ces conditions entrainent un refus immediat sans verification humaine
# ==============================================================================
REFUS_DIRECTS = [
    ("has_dui_5yr",                True,  "DUI dans les 5 dernières années"),
    ("has_criminal_record_10yr",   True,  "Casier judiciaire dans les 10 ans"),
    ("refused_insurance_3yr",      True,  "Assurance refusée dans les 3 ans"),
    ("refused_to_provide_info",    True,  "Refus de fournir informations"),
    ("no_insurable_interest",      True,  "Aucun intérêt assurable"),
    ("owes_money_to_desjardins",   True,  "Dette envers Desjardins"),
    ("has_misrepresentation_history", True, "Historique de fausse déclaration"),
    ("licence_suspension_3yr",     True,  "Suspension de permis dans les 3 ans"),
]

def verifier_refus_directs(applicant: dict) -> dict:
    """Verifie si la demande doit etre refusee directement"""
    raisons = []
    for col, val_refus, description in REFUS_DIRECTS:
        val = applicant.get(col, False)
        if str(val).lower() in ["true", "1", "yes"]:
            raisons.append(description)

    if raisons:
        return {"refuse": True, "raisons": raisons}
    return {"refuse": False}

# ==============================================================================
# SECTION 3 : VERIFICATION VEHICULE (refus direct si valeur >= 500,000)
# ==============================================================================
def verifier_vehicule_refus(vehicle: dict) -> dict:
    """Verifie si le vehicule doit etre refuse directement"""
    raisons = []
    val = float(vehicle.get("vehicle_value", 0) or 0)
    if val >= 500_000:
        raisons.append(f"Valeur véhicule trop élevée ({val:,.0f}$)")
    if str(vehicle.get("is_kit_car", False)).lower() in ["true", "1", "yes"]:
        raisons.append("Véhicule kit car")
    if str(vehicle.get("is_used_on_racetrack", False)).lower() in ["true", "1", "yes"]:
        raisons.append("Véhicule utilisé sur circuit")

    if raisons:
        return {"refuse": True, "raisons": raisons}
    return {"refuse": False}

