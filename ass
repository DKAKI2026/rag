# ==============================================================================
# AGENT : Évaluation d'une demande (async)
# NOTE  : Dans le nouveau pipeline, cet agent est appelé via orchestrateur.py
#         qui injecte la tarification VMR avant de générer l'explication.
#         Cet agent reste disponible en standalone pour la compatibilité.
# ==============================================================================
async def agent_evaluer_demande(applicant: dict, vehicle_data: dict) -> dict:
    """
    Évalue une demande d'assurance et génère une explication GPT.
    ⚠️ En standalone, l'estimation tarifaire sera absente (pas de VMR).
       Préférer orchestrateur.orchestrer_evaluation() pour le pipeline complet.
    """
    openai_client = get_openai_client()

    additional_drivers = get_conducteurs_additionnels(str(applicant.get("applicant_id", "")))
    evaluation         = evaluer_demande(applicant, vehicle_data, additional_drivers)
    demande_id         = creer_demande(applicant, vehicle_data, evaluation)
    evaluation["demande_id"] = demande_id

    statut   = evaluation["statut"]
    score    = evaluation["score"]
    details  = "\n".join(evaluation.get("details", []))
    triggers = "\n".join([t["description"] for t in evaluation.get("triggers", [])])
    est      = evaluation.get("estimation") or {}

    prompt = f"""
Tu es un agent d'assurance automobile de Desjardins.
Explique au client le résultat de son évaluation d'assurance de façon claire et professionnelle en français.

Statut          : {statut}
Score de risque : {score}/12
Détails calcul  : {details}
Triggers        : {triggers or 'aucun'}
Prime estimée   : {est.get('prime_annuelle', 'N/A')}$ / an

Règles :
- Si REFUSE            : explique pourquoi sans être brutal, exprime de la compassion
- Si VERIFICATION_HUMAINE : explique que la demande est en cours de traitement (1-3 jours ouvrables)
- Si APPROUVE          : félicite et donne les détails de la prime
- Sois concis (max 150 mots), professionnel et humain.
"""

    response = openai_client.chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[{"role": "user", "content": prompt}],
        max_tokens=300,
        temperature=0.4,
    )

    evaluation["explication_client"] = response.choices[0].message.content
    return evaluation


# ==============================================================================
# AGENT : Analyse employé (async)
# Utilisé par orchestrateur.orchestrer_analyse_employe()
# ==============================================================================
async def agent_analyse_employe(demande: dict) -> dict:
    """
    Analyse une demande pour aider l'employé à prendre une décision.
    Tient compte de la tarification VMR si disponible dans la demande.
    """
    openai_client = get_openai_client()

    vmr_context = ""
    if demande.get("groupe_vmr"):
        vmr_context = f"""
- Groupe VMR          : {demande.get('groupe_vmr')} (source : {demande.get('source_vmr','N/A')})
- Justification VMR   : {demande.get('justification_vmr','')}
- Souscription spéc.  : {demande.get('necessite_souscription_specialisee', False)}"""

    prompt = f"""Tu es un souscripteur senior chez Desjardins Assurances.
Analyse cette demande d'assurance et donne une recommandation claire à l'employé.

Informations demande :
- Client            : {demande.get('first_name')} {demande.get('last_name')}
- Véhicule          : {demande.get('vehicle_year')} {demande.get('vehicle_make')} {demande.get('vehicle_model')}
- Valeur véhicule   : {demande.get('vehicle_value')}$
- Score risque      : {demande.get('score_risque')}
- Profil conducteur : {demande.get('profil_conducteur')}{vmr_context}
- Triggers          : {demande.get('triggers')}
- Prime estimée     : {demande.get('prime_annuelle')}$/an  ({demande.get('prime_mensuelle')}$/mois)

Fournis :
1. Analyse du risque (2-3 phrases)
2. Points d'attention spécifiques (VMR, triggers, profil)
3. Recommandation : APPROUVER / REFUSER + justification courte
"""

    response = openai_client.chat.completions.create(
        model=AZURE_OPENAI_DEPLOYMENT,
        messages=[{"role": "user", "content": prompt}],
        max_tokens=400,
        temperature=0.3,
    )

    return {
        "analyse_employe": response.choices[0].message.content,
        "demande_id"     : demande.get("demande_id", ""),
    }


