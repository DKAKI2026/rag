# ==============================================================================
# FICHIER : backend/rules/decisions.py
# ROLE    : Moteur de decision final — accepte / verification_humaine / refuse
# ==============================================================================

from backend.rules.blacklist import verifier_vin_blacklist, verifier_refus_directs, verifier_vehicule_refus
from backend.rules.scoring   import calculer_score_total

# ==============================================================================
# STATUTS POSSIBLES
# ==============================================================================
STATUT_REFUSE           = "REFUSE"
STATUT_VERIFICATION     = "VERIFICATION_HUMAINE"
STATUT_APPROUVE         = "APPROUVE"

# ==============================================================================
# SECTION 1 : TRIGGERS POUR VERIFICATION HUMAINE
# ==============================================================================
TRIGGERS_HUMAIN = [
    ("vehicle_value",             lambda v: 200_000 <= float(v or 0) < 500_000, "Véhicule haute valeur (200k-500k$)",         "high_value_vehicle"),
    ("is_modified",               lambda v: str(v).lower() in ["true","1","yes"], "Véhicule modifié",                         "modified_vehicle"),
    ("is_salvage",                lambda v: str(v).lower() in ["true","1","yes"], "Véhicule salvage",                         "salvage_or_rebuilt"),
    ("is_rebuilt",                lambda v: str(v).lower() in ["true","1","yes"], "Véhicule reconstruit",                     "salvage_or_rebuilt"),
    ("has_gap_in_coverage",       lambda v: str(v).lower() in ["true","1","yes"], "Interruption de couverture",               "gap_in_coverage"),
    ("has_foreign_driving_experience", lambda v: str(v).lower() in ["true","1","yes"], "Expérience de conduite étrangère",   "foreign_experience"),
    ("commercial_use_description",lambda v: v and len(str(v)) > 5,               "Usage commercial borderline",               "commercial_use_borderline"),
]

def verifier_triggers_humain(applicant: dict, vehicle: dict) -> list:
    """Retourne la liste des triggers de verification humaine"""
    triggers = []

    # Triggers vehicule
    for col, condition, desc, code in TRIGGERS_HUMAIN:
        src = vehicle if col in ["vehicle_value","is_modified","is_salvage","is_rebuilt","commercial_use_description"] else applicant
        val = src.get(col)
        if val is not None and condition(val):
            triggers.append({"code": code, "description": desc})

    # years_prior_insurance = 0
    if int(applicant.get("years_prior_insurance", 1) or 1) == 0:
        triggers.append({"code": "gap_in_coverage", "description": "Aucune assurance préalable"})

    # Modification value >= 2000
    if str(vehicle.get("is_modified","")).lower() in ["true","1","yes"]:
        mod_val = float(vehicle.get("modification_value_cad", 0) or 0)
        if mod_val < 2000:
            # Enlever le trigger si modification < 2000
            triggers = [t for t in triggers if t["code"] != "modified_vehicle"]

    return triggers

# ==============================================================================
# SECTION 2 : DECISION FINALE
# ==============================================================================
def evaluer_demande(applicant: dict, vehicle: dict, additional_drivers: list = None) -> dict:
    """
    Evalue une demande d'assurance et retourne la decision finale.

    Retourne un dict avec :
    - statut       : REFUSE / VERIFICATION_HUMAINE / APPROUVE
    - score        : score de risque calcule
    - raisons      : liste des raisons
    - triggers     : triggers de verification humaine
    - details      : details du calcul de score
    - estimation   : estimation tarifaire approximative
    """
    if additional_drivers is None:
        additional_drivers = []

    raisons_refus    = []
    triggers_humain  = []

    # ── ETAPE 1 : Verification VIN blacklist ───────────────────────
    vin = vehicle.get("vin", "")
    if vin:
        vin_check = verifier_vin_blacklist(vin)
        if vin_check["blacklisted"]:
            return {
                "statut"    : STATUT_REFUSE,
                "score"     : 0,
                "raisons"   : [f"VIN blacklisté : {vin_check['reason']}"],
                "triggers"  : [],
                "details"   : ["Refus automatique — VIN dans liste noire"],
                "estimation": None,
            }

    # ── ETAPE 2 : Refus directs applicant ─────────────────────────
    refus_app = verifier_refus_directs(applicant)
    if refus_app["refuse"]:
        return {
            "statut"    : STATUT_REFUSE,
            "score"     : 0,
            "raisons"   : refus_app["raisons"],
            "triggers"  : [],
            "details"   : ["Refus automatique — critères d'exclusion directe"],
            "estimation": None,
        }

    # ── ETAPE 3 : Refus direct vehicule ───────────────────────────
    refus_veh = verifier_vehicule_refus(vehicle)
    if refus_veh["refuse"]:
        return {
            "statut"    : STATUT_REFUSE,
            "score"     : 0,
            "raisons"   : refus_veh["raisons"],
            "triggers"  : [],
            "details"   : ["Refus automatique — véhicule non assurable"],
            "estimation": None,
        }

    # ── ETAPE 4 : Calcul score de risque ──────────────────────────
    score_result = calculer_score_total(applicant, additional_drivers)
    score        = score_result["score_total"]

    if score_result["depasse_seuil"]:
        return {
            "statut"    : STATUT_REFUSE,
            "score"     : score,
            "raisons"   : [f"Score de risque trop élevé : {score} pts (seuil : 12)"],
            "triggers"  : [],
            "details"   : score_result["details"],
            "estimation": None,
        }

    # ── ETAPE 5 : Triggers verification humaine ───────────────────
    triggers = verifier_triggers_humain(applicant, vehicle)

    # Selon la consigne : TOUTE demande (sauf blacklist) = verification humaine
    # On force toujours VERIFICATION_HUMAINE sauf refus direct
    triggers_humain = triggers if triggers else [{"code": "standard_review", "description": "Vérification standard requise"}]

    # ── ETAPE 6 : Estimation tarifaire ────────────────────────────
    estimation = calculer_estimation(applicant, vehicle, score, score_result["profile_principal"])

    return {
        "statut"    : STATUT_VERIFICATION,
        "score"     : score,
        "raisons"   : [],
        "triggers"  : triggers_humain,
        "details"   : score_result["details"],
        "estimation": estimation,
    }

# ==============================================================================
# SECTION 3 : ESTIMATION TARIFAIRE
# Formule simplifiee basee sur les donnees disponibles
# ==============================================================================
def calculer_estimation(applicant: dict, vehicle: dict, score: int, profile: int) -> dict:
    """Calcule une estimation approximative de la prime annuelle"""
    base = 1200.0

    # Ajustement vehicule
    val_veh = float(vehicle.get("vehicle_value", 20000) or 20000)
    base += val_veh * 0.005

    # Ajustement profil
    ajust_profil = {1: 1.0, 2: 1.15, 3: 1.35}
    base *= ajust_profil.get(profile, 1.0)

    # Ajustement score
    base *= (1 + score * 0.08)

    # Ajustements specifiques
    if str(vehicle.get("has_winter_tires","")).lower() in ["true","1","yes"]:
        base *= 0.95  # -5% pneus hiver
    if str(vehicle.get("has_anti_theft","")).lower() in ["true","1","yes"]:
        base *= 0.97  # -3% antivol
    if str(applicant.get("completed_driving_course","")).lower() in ["true","1","yes"]:
        base *= 0.95  # -5% cours conduite
    if str(applicant.get("is_existing_desjardins_member","")).lower() in ["true","1","yes"]:
        base *= 0.95  # -5% membre existant
    if str(applicant.get("has_home_insurance","")).lower() in ["true","1","yes"]:
        base *= 0.93  # -7% assurance habitation

    prime_annuelle = round(base, 2)
    return {
        "prime_annuelle"  : prime_annuelle,
        "prime_mensuelle" : round(prime_annuelle / 12, 2),
        "score_risque"    : score,
        "profil"          : profile,
    }
