def mettre_a_jour_approbation_client(demande_id: str) -> bool:
    """Met à jour le statut après approbation finale du client."""
    try:
        init_fichier()
        df   = pd.read_excel(DEMANDES_FILE)
        mask = df["demande_id"].astype(str) == str(demande_id)
        if mask.sum() == 0:
            return False
        df.loc[mask, "statut"]              = "APPROUVE_CLIENT"
        df.loc[mask, "date_approbation_client"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        df.to_excel(DEMANDES_FILE, index=False)
        return True
    except Exception as e:
        print(f"Erreur approbation client : {e}")
        return False

