    lire_table, ajouter_ligne, modifier_ligne, supprimer_ligne,
    initialiser_tables, tester_connexion, importer_depuis_excel,
    TABLE_STOCKS, TABLE_COMMANDES, TABLE_CLIENTS
)
from backend.config.settings             import COMPANY_NAME
from components.navbar                   import get_navbar, inject_base_css
from frontend.styles.gestion_donnees_css import GESTION_CSS

st.set_page_config(page_title=f"{COMPANY_NAME} — Gestion", page_icon="📝", layout="wide", initial_sidebar_state="collapsed")
st.markdown(inject_base_css(), unsafe_allow_html=True)
st.markdown(GESTION_CSS,       unsafe_allow_html=True)
nb_alertes = len(st.session_state.get("alertes_stocks", []))
st.markdown(get_navbar("Gestion Donnees", nb_alertes), unsafe_allow_html=True)

if "gd_notifs" not in st.session_state: st.session_state.gd_notifs = []
if "sql_ok"    not in st.session_state: st.session_state.sql_ok    = None

def add_notif(msg, kind="success"):
    st.session_state.gd_notifs.append({"msg": msg, "kind": kind})
    if len(st.session_state.gd_notifs) > 3:
        st.session_state.gd_notifs.pop(0)

if st.session_state.sql_ok is None:
    st.session_state.sql_ok = tester_connexion()

sql_badge = '<span class="gd-badge green">SQL Connecte</span>' if st.session_state.sql_ok else '<span class="gd-badge red">SQL Deconnecte</span>'

st.markdown(f"""
<div class="gd-hero">
  <div class="gd-eyebrow">CRUD — Azure SQL Database</div>
  <h1>Gestion des <em>Donnees</em></h1>
  <p class="gd-hero-desc">Ajoutez, modifiez et supprimez vos stocks, commandes et clients. {sql_badge}</p>
</div>
""", unsafe_allow_html=True)

for n in st.session_state.gd_notifs:
    st.markdown(f'<div class="gd-notif {n["kind"]}">{n["msg"]}</div>', unsafe_allow_html=True)

if not st.session_state.sql_ok:
    st.error("Impossible de se connecter a Azure SQL.")
    if st.button("Reessayer"):
        st.session_state.sql_ok = tester_connexion()
        st.rerun()
    st.stop()

if st.button("Initialiser les tables SQL (premiere fois)"):
    with st.spinner("Creation..."):
        try:
            initialiser_tables()
            add_notif("Tables creees !", "success")
        except Exception as e:
            add_notif(f"Erreur : {e}", "error")
    st.rerun()

tab_stocks, tab_commandes, tab_clients, tab_import = st.tabs(["Stocks","Commandes","Clients","Import Excel"])

# ── STOCKS ────────────────────────────────────────────────────────
with tab_stocks:
    cl, cf = st.columns([3,2], gap="medium")
    with cl:
        st.markdown('<p class="gd-sec-title">Liste</p>', unsafe_allow_html=True)
        if st.button("Actualiser", key="ref_s"): st.rerun()
        df = lire_table(TABLE_STOCKS)
        if df.empty: st.info("Aucun stock.")
        else:
            st.dataframe(df, use_container_width=True, height=400)
            st.markdown('<p class="gd-sec-title">Supprimer</p>', unsafe_allow_html=True)
            c1,c2 = st.columns([3,1])
            with c1: id_del = st.selectbox("Piece", df["ID_Piece"].tolist(), key="del_s")
            with c2:
                st.markdown("<br>", unsafe_allow_html=True)
                if st.button("Supprimer", key="btn_del_s"):
                    ok = supprimer_ligne(TABLE_STOCKS,"ID_Piece",id_del)
                    add_notif(f"{id_del} supprimee" if ok else "Erreur", "success" if ok else "error")
                    st.rerun()
    with cf:
        st.markdown('<p class="gd-sec-title">Ajouter / Modifier</p>', unsafe_allow_html=True)
        mode = st.radio("Mode",["Ajouter","Modifier"],horizontal=True,key="mode_s")
        with st.form("form_s"):
            id_p = st.text_input("ID Piece *",  placeholder="P001")
            nom  = st.text_input("Nom piece *", placeholder="Filtre a huile")
            qte  = st.number_input("Quantite",  min_value=0, value=0)
            seu  = st.number_input("Seuil min", min_value=0, value=5)
            dliv = st.date_input("Date livraison", value=None)
            fou  = st.text_input("Fournisseur")
            mod  = st.text_input("Modele voiture")
            sub  = st.form_submit_button(mode, use_container_width=True)
        if sub:
            if not id_p or not nom: add_notif("ID et Nom obligatoires.","warn")
            else:
                d = {"Nom_Piece":nom,"Quantite":qte,"Seuil_Minimum":seu,"Date_Livraison_Prevue":str(dliv) if dliv else None,"Fournisseur":fou or None,"Modele_Voiture":mod or None}
                if mode=="Ajouter": d["ID_Piece"]=id_p; ok=ajouter_ligne(TABLE_STOCKS,d)
                else: ok=modifier_ligne(TABLE_STOCKS,"ID_Piece",id_p,d)
                add_notif(f"Piece {id_p} {'ajoutee' if mode=='Ajouter' else 'modifiee'} !" if ok else "Erreur","success" if ok else "error")
            st.rerun()

# ── COMMANDES ─────────────────────────────────────────────────────
with tab_commandes:
    cl, cf = st.columns([3,2], gap="medium")
    with cl:
        st.markdown('<p class="gd-sec-title">Liste</p>', unsafe_allow_html=True)
        if st.button("Actualiser", key="ref_c"): st.rerun()
        df = lire_table(TABLE_COMMANDES)
        if df.empty: st.info("Aucune commande.")
        else:
            st.dataframe(df, use_container_width=True, height=400)
            st.markdown('<p class="gd-sec-title">Supprimer</p>', unsafe_allow_html=True)
            c1,c2 = st.columns([3,1])
            with c1: id_del = st.selectbox("Commande", df["ID_Commande"].tolist(), key="del_c")
            with c2:
                st.markdown("<br>", unsafe_allow_html=True)
                if st.button("Supprimer", key="btn_del_c"):
                    ok = supprimer_ligne(TABLE_COMMANDES,"ID_Commande",id_del)
                    add_notif(f"{id_del} supprimee" if ok else "Erreur","success" if ok else "error")
                    st.rerun()
    with cf:
        st.markdown('<p class="gd-sec-title">Ajouter / Modifier</p>', unsafe_allow_html=True)
        mode = st.radio("Mode",["Ajouter","Modifier"],horizontal=True,key="mode_c")
        with st.form("form_c"):
            id_c = st.text_input("ID Commande *", placeholder="CMD-2026-001")
            cli  = st.text_input("Nom client *",  placeholder="Jean Tremblay")
            modv = st.text_input("Modele voiture *", placeholder="Honda Civic 2026")
            datc = st.date_input("Date commande", value=date.today())
            stat = st.selectbox("Statut",["En cours","Confirme","Livre","Annule"])
            mont = st.number_input("Montant ($)", min_value=0.0, value=0.0, step=100.0)
            vend = st.text_input("Vendeur")
            sub  = st.form_submit_button(mode, use_container_width=True)
        if sub:
            if not id_c or not cli or not modv: add_notif("ID, Client et Modele obligatoires.","warn")
            else:
                d = {"Nom_Client":cli,"Modele_Voiture":modv,"Date_Commande":str(datc),"Statut":stat,"Montant_Total":mont,"Vendeur":vend or None}
                if mode=="Ajouter": d["ID_Commande"]=id_c; ok=ajouter_ligne(TABLE_COMMANDES,d)
                else: ok=modifier_ligne(TABLE_COMMANDES,"ID_Commande",id_c,d)
                add_notif(f"Commande {id_c} {'ajoutee' if mode=='Ajouter' else 'modifiee'} !" if ok else "Erreur","success" if ok else "error")
            st.rerun()

# ── CLIENTS ───────────────────────────────────────────────────────
with tab_clients:
    cl, cf = st.columns([3,2], gap="medium")
    with cl:
        st.markdown('<p class="gd-sec-title">Liste</p>', unsafe_allow_html=True)
        if st.button("Actualiser", key="ref_cl"): st.rerun()
        df = lire_table(TABLE_CLIENTS)
        if df.empty: st.info("Aucun client.")
        else:
            st.dataframe(df, use_container_width=True, height=400)
            st.markdown('<p class="gd-sec-title">Supprimer</p>', unsafe_allow_html=True)
            c1,c2 = st.columns([3,1])
            with c1: id_del = st.selectbox("Client", df["ID_Client"].tolist(), key="del_cl")
            with c2:
                st.markdown("<br>", unsafe_allow_html=True)
                if st.button("Supprimer", key="btn_del_cl"):
                    ok = supprimer_ligne(TABLE_CLIENTS,"ID_Client",id_del)
                    add_notif(f"{id_del} supprime" if ok else "Erreur","success" if ok else "error")
                    st.rerun()
    with cf:
        st.markdown('<p class="gd-sec-title">Ajouter / Modifier</p>', unsafe_allow_html=True)
        mode = st.radio("Mode",["Ajouter","Modifier"],horizontal=True,key="mode_cl")
        with st.form("form_cl"):
            id_cl = st.text_input("ID Client *", placeholder="C001")
            nom   = st.text_input("Nom client *", placeholder="Pierre Martin")
            eml   = st.text_input("Email")
            tel   = st.text_input("Telephone")
            ach   = st.number_input("Nombre achats", min_value=0, value=0)
            val   = st.number_input("Valeur totale ($)", min_value=0.0, value=0.0, step=100.0)
            dvis  = st.date_input("Derniere visite", value=date.today())
            niv   = st.selectbox("Niveau fidelite",["Bronze","Argent","Or","Platine"])
            sub   = st.form_submit_button(mode, use_container_width=True)
        if sub:
            if not id_cl or not nom: add_notif("ID et Nom obligatoires.","warn")
            else:
                d = {"Nom_Client":nom,"Email":eml or None,"Telephone":tel or None,"Nombre_Achats":ach,"Valeur_Totale":val,"Derniere_Visite":str(dvis),"Niveau_Fidelite":niv}
                if mode=="Ajouter": d["ID_Client"]=id_cl; ok=ajouter_ligne(TABLE_CLIENTS,d)
                else: ok=modifier_ligne(TABLE_CLIENTS,"ID_Client",id_cl,d)
                add_notif(f"Client {id_cl} {'ajoute' if mode=='Ajouter' else 'modifie'} !" if ok else "Erreur","success" if ok else "error")
            st.rerun()

# ── IMPORT EXCEL ──────────────────────────────────────────────────
with tab_import:
    st.markdown('<p class="gd-sec-title">Importer Excel vers Azure SQL</p>', unsafe_allow_html=True)
    st.markdown('<div class="gd-import-info">Importez vos fichiers Excel dans Azure SQL. Les colonnes doivent correspondre a celles de settings.py.</div>', unsafe_allow_html=True)
    c1,c2 = st.columns(2)
    with c1:
        f = st.file_uploader("stocks.xlsx", type=["xlsx"], key="up_s")
        if f and st.button("Importer Stocks"):
            import tempfile,os
            with tempfile.NamedTemporaryFile(delete=False,suffix=".xlsx") as tmp: tmp.write(f.read()); p=tmp.name
            i,e = importer_depuis_excel(TABLE_STOCKS,p,"ID_Piece"); os.unlink(p)
            add_notif(f"Stocks : {i} inseres, {e} erreurs","success" if e==0 else "warn"); st.rerun()
        f = st.file_uploader("commandes.xlsx", type=["xlsx"], key="up_c")
        if f and st.button("Importer Commandes"):
            import tempfile,os
            with tempfile.NamedTemporaryFile(delete=False,suffix=".xlsx") as tmp: tmp.write(f.read()); p=tmp.name
            i,e = importer_depuis_excel(TABLE_COMMANDES,p,"ID_Commande"); os.unlink(p)
            add_notif(f"Commandes : {i} inserees, {e} erreurs","success" if e==0 else "warn"); st.rerun()
    with c2:
        f = st.file_uploader("clients.xlsx", type=["xlsx"], key="up_cl")
        if f and st.button("Importer Clients"):
            import tempfile,os
            with tempfile.NamedTemporaryFile(delete=False,suffix=".xlsx") as tmp: tmp.write(f.read()); p=tmp.name
            i,e = importer_depuis_excel(TABLE_CLIENTS,p,"ID_Client"); os.unlink(p)
            add_notif(f"Clients : {i} inseres, {e} erreurs","success" if e==0 else "warn"); st.rerun()
        if st.button("Voir les stats SQL"):
            try:
                nb_s=len(lire_table(TABLE_STOCKS)); nb_c=len(lire_table(TABLE_COMMANDES)); nb_cl=len(lire_table(TABLE_CLIENTS))
                st.markdown(f'<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:1rem"><div class="gd-stats-grid"><div><div class="gd-stat-val" style="color:var(--accent)">{nb_s}</div><div class="gd-stat-lbl">Stocks</div></div><div><div class="gd-stat-val" style="color:var(--blue)">{nb_c}</div><div class="gd-stat-lbl">Commandes</div></div><div><div class="gd-stat-val" style="color:var(--amber)">{nb_cl}</div><div class="gd-stat-lbl">Clients</div></div></div></div>', unsafe_allow_html=True)
            except Exception as e: st.error(f"Erreur : {e}")

