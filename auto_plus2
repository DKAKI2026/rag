# ==============================================================================
# FICHIER : backend/utils/sql.py
# ROLE    : Connexion et operations CRUD Azure SQL Database
# USAGE   : from backend.utils.sql import lire_table, ajouter_ligne, ...
# ==============================================================================

import os
import pandas as pd
from dotenv import load_dotenv

load_dotenv()

# ==============================================================================
# SECTION 1 : CONFIGURATION SQL
# → Copiez depuis portal.azure.com > SQL Database > Chaines de connexion
# ==============================================================================
SQL_SERVER   = os.getenv("SQL_SERVER",   "sql-dev-cacn-team013-hack.database.windows.net")
SQL_DATABASE = os.getenv("SQL_DATABASE", "sqldb-dev-cacn-team013-hack-ai")
SQL_DRIVER   = os.getenv("SQL_DRIVER",   "ODBC Driver 18 for SQL Server")

# ==============================================================================
# SECTION 2 : NOMS DES TABLES
# → Changez si vous utilisez des noms differents
# ==============================================================================
TABLE_STOCKS    = "stocks"
TABLE_COMMANDES = "commandes"
TABLE_CLIENTS   = "clients"

def get_connection():
    """Connexion Azure SQL avec ManagedIdentityCredential"""
    import pyodbc
    from azure.identity import ManagedIdentityCredential
    import struct
    credential   = ManagedIdentityCredential()
    token        = credential.get_token("https://database.windows.net/.default")
    token_bytes  = token.token.encode("UTF-16-LE")
    token_struct = struct.pack(f"<I{len(token_bytes)}s", len(token_bytes), token_bytes)
    conn_str = (
        f"DRIVER={{{SQL_DRIVER}}};"
        f"SERVER={SQL_SERVER};"
        f"DATABASE={SQL_DATABASE};"
        f"Encrypt=yes;"
        f"TrustServerCertificate=no;"
    )
    return pyodbc.connect(conn_str, attrs_before={1256: token_struct})

def tester_connexion() -> bool:
    try:
        conn = get_connection()
        conn.close()
        return True
    except Exception as e:
        print(f"Erreur SQL : {e}")
        return False

def initialiser_tables():
    """Cree les 3 tables si elles n'existent pas — a lancer UNE SEULE FOIS"""
    conn   = get_connection()
    cursor = conn.cursor()
    cursor.execute("""
    IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='stocks' AND xtype='U')
    CREATE TABLE stocks (
        ID_Piece              NVARCHAR(50)  PRIMARY KEY,
        Nom_Piece             NVARCHAR(200) NOT NULL,
        Quantite              INT           NOT NULL DEFAULT 0,
        Seuil_Minimum         INT           NOT NULL DEFAULT 5,
        Date_Livraison_Prevue DATE          NULL,
        Fournisseur           NVARCHAR(200) NULL,
        Modele_Voiture        NVARCHAR(200) NULL,
        Date_Mise_A_Jour      DATETIME      DEFAULT GETDATE()
    )""")
    cursor.execute("""
    IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='commandes' AND xtype='U')
    CREATE TABLE commandes (
        ID_Commande      NVARCHAR(50)   PRIMARY KEY,
        Nom_Client       NVARCHAR(200)  NOT NULL,
        Modele_Voiture   NVARCHAR(200)  NOT NULL,
        Date_Commande    DATE           NOT NULL,
        Statut           NVARCHAR(50)   NOT NULL DEFAULT 'En cours',
        Montant_Total    DECIMAL(10,2)  NOT NULL DEFAULT 0,
        Vendeur          NVARCHAR(200)  NULL,
        Date_Mise_A_Jour DATETIME       DEFAULT GETDATE()
    )""")
    cursor.execute("""
    IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='clients' AND xtype='U')
    CREATE TABLE clients (
        ID_Client        NVARCHAR(50)   PRIMARY KEY,
        Nom_Client       NVARCHAR(200)  NOT NULL,
        Email            NVARCHAR(200)  NULL,
        Telephone        NVARCHAR(50)   NULL,
        Nombre_Achats    INT            NOT NULL DEFAULT 0,
        Valeur_Totale    DECIMAL(12,2)  NOT NULL DEFAULT 0,
        Derniere_Visite  DATE           NULL,
        Niveau_Fidelite  NVARCHAR(50)   NOT NULL DEFAULT 'Bronze',
        Date_Mise_A_Jour DATETIME       DEFAULT GETDATE()
    )""")
    conn.commit()
    conn.close()
    print("Tables initialisees !")

def lire_table(table: str) -> pd.DataFrame:
    try:
        conn = get_connection()
        df   = pd.read_sql(f"SELECT * FROM {table}", conn)
        conn.close()
        return df
    except Exception as e:
        print(f"Erreur lecture {table} : {e}")
        return pd.DataFrame()

def ajouter_ligne(table: str, donnees: dict) -> bool:
    try:
        conn   = get_connection()
        cursor = conn.cursor()
        cols   = ", ".join(donnees.keys())
        ph     = ", ".join(["?" for _ in donnees])
        cursor.execute(f"INSERT INTO {table} ({cols}) VALUES ({ph})", list(donnees.values()))
        conn.commit()
        conn.close()
        return True
    except Exception as e:
        print(f"Erreur ajout : {e}")
        return False

def modifier_ligne(table: str, cle: str, id_val: str, donnees: dict) -> bool:
    try:
        conn   = get_connection()
        cursor = conn.cursor()
        sets   = ", ".join([f"{k} = ?" for k in donnees.keys()])
        vals   = list(donnees.values()) + [id_val]
        cursor.execute(f"UPDATE {table} SET {sets}, Date_Mise_A_Jour = GETDATE() WHERE {cle} = ?", vals)
        conn.commit()
        conn.close()
        return True
    except Exception as e:
        print(f"Erreur modification : {e}")
        return False

def supprimer_ligne(table: str, cle: str, id_val: str) -> bool:
    try:
        conn   = get_connection()
        cursor = conn.cursor()
        cursor.execute(f"DELETE FROM {table} WHERE {cle} = ?", [id_val])
        conn.commit()
        conn.close()
        return True
    except Exception as e:
        print(f"Erreur suppression : {e}")
        return False

def importer_depuis_excel(table: str, fichier: str, cle: str) -> tuple:
    try:
        df      = pd.read_excel(fichier)
        inseres = 0
        erreurs = 0
        for _, row in df.iterrows():
            donnees = {k: (None if pd.isna(v) else v) for k, v in row.items()}
            if ajouter_ligne(table, donnees):
                inseres += 1
            else:
                erreurs += 1
        return inseres, erreurs
    except Exception as e:
        return 0, 0

