# ==============================================================================
# FICHIER : pages/4_Azure_SQL.py
# ROLE    : Configuration et monitoring Azure SQL Database
# CSS     : importe depuis frontend/styles/azure_sql_css.py
# ==============================================================================

import streamlit as st

from backend.utils.sql import (
    tester_connexion, initialiser_tables, lire_table,
    TABLE_STOCKS, TABLE_COMMANDES, TABLE_CLIENTS,
    SQL_SERVER, SQL_DATABASE
)
from backend.config.settings       import COMPANY_NAME
from components.navbar             import get_navbar, inject_base_css
from frontend.styles.azure_sql_css import SQL_CSS

st.set_page_config(page_title=f"{COMPANY_NAME} — Azure SQL", page_icon="🗄️", layout="wide", initial_sidebar_state="collapsed")
st.markdown(inject_base_css(), unsafe_allow_html=True)
st.markdown(SQL_CSS,           unsafe_allow_html=True)
st.markdown(get_navbar("Azure SQL"), unsafe_allow_html=True)

if "sql_notifs" not in st.session_state: st.session_state.sql_notifs = []

def add_notif(msg, kind="success"):
    st.session_state.sql_notifs.append({"msg": msg, "kind": kind})
    if len(st.session_state.sql_notifs) > 3: st.session_state.sql_notifs.pop(0)

connexion_ok = tester_connexion()
badge = '<span class="sql-badge green">Connecte</span>' if connexion_ok else '<span class="sql-badge red">Deconnecte</span>'

st.markdown(f"""
<div class="sql-hero">
  <div class="sql-eyebrow">Azure SQL Database</div>
  <h1>Configuration <em>Azure SQL</em></h1>
  <p class="sql-hero-desc">Gerez votre connexion a Azure SQL et surveillez vos tables. {badge}</p>
</div>
""", unsafe_allow_html=True)

for n in st.session_state.sql_notifs:
    st.markdown(f'<div class="sql-notif {n["kind"]}">{n["msg"]}</div>', unsafe_allow_html=True)

c1, c2 = st.columns([3,2], gap="medium")

with c1:
    st.markdown('<p class="sql-sec-title">Informations de connexion</p>', unsafe_allow_html=True)
    st.markdown(f"""
    <div class="sql-conn-card">
      <div class="sql-info-row"><span class="sql-info-label">Serveur</span><span class="sql-info-val">{SQL_SERVER}</span></div>
      <div class="sql-info-row"><span class="sql-info-label">Base de donnees</span><span class="sql-info-val">{SQL_DATABASE}</span></div>
      <div class="sql-info-row"><span class="sql-info-label">Authentification</span><span class="sql-info-val">ManagedIdentityCredential</span></div>
      <div class="sql-info-row"><span class="sql-info-label">Driver</span><span class="sql-info-val">ODBC Driver 18 for SQL Server</span></div>
      <div class="sql-info-row"><span class="sql-info-label">Chiffrement</span><span class="sql-info-val">TLS 1.2 — Encrypt=yes</span></div>
    </div>
    """, unsafe_allow_html=True)
    st.markdown('<p class="sql-sec-title" style="margin-top:1rem">Variables .env requises</p>', unsafe_allow_html=True)
    st.markdown(f'<div class="sql-query-box">SQL_SERVER={SQL_SERVER}<br>SQL_DATABASE={SQL_DATABASE}<br>SQL_DRIVER=ODBC Driver 18 for SQL Server</div>', unsafe_allow_html=True)

    if connexion_ok:
        st.markdown('<p class="sql-sec-title" style="margin-top:1rem">Statistiques tables</p>', unsafe_allow_html=True)
        cs1,cs2,cs3 = st.columns(3)
        for table,label,color,col in [(TABLE_STOCKS,"Stocks","var(--accent)",cs1),(TABLE_COMMANDES,"Commandes","var(--blue)",cs2),(TABLE_CLIENTS,"Clients","var(--amber)",cs3)]:
            with col:
                try:
                    nb = len(lire_table(table))
                    st.markdown(f'<div class="sql-table-stat"><div class="sql-table-stat-val" style="color:{color}">{nb}</div><div class="sql-table-stat-lbl">{label}</div></div>', unsafe_allow_html=True)
                except:
                    st.markdown(f'<div class="sql-table-stat"><div class="sql-table-stat-val" style="color:var(--red)">?</div><div class="sql-table-stat-lbl">{label}</div></div>', unsafe_allow_html=True)

with c2:
    st.markdown('<p class="sql-sec-title">Actions</p>', unsafe_allow_html=True)
    if st.button("Tester la connexion", use_container_width=True):
        ok = tester_connexion()
        add_notif("Connexion reussie !" if ok else "Connexion echouee", "success" if ok else "error")
        st.rerun()
    if st.button("Initialiser les tables", use_container_width=True):
        if not connexion_ok: add_notif("Connexion requise.","error")
        else:
            with st.spinner("Creation..."):
                try: initialiser_tables(); add_notif("Tables creees !","success")
                except Exception as e: add_notif(f"Erreur : {e}","error")
        st.rerun()

    st.markdown('<p class="sql-sec-title" style="margin-top:1rem">Requete SQL</p>', unsafe_allow_html=True)
    st.markdown('<div class="sql-warning">Utilisez avec precaution.</div>', unsafe_allow_html=True)
    with st.form("sql_q"):
        req = st.text_area("Requete", value="SELECT TOP 10 * FROM stocks", height=100)
        run = st.form_submit_button("Executer", use_container_width=True)
    if run and req.strip():
        if not connexion_ok: add_notif("Connexion requise.","error")
        else:
            try:
                from backend.utils.sql import get_connection
                import pandas as pd
                conn=get_connection(); df=pd.read_sql(req,conn); conn.close()
                st.dataframe(df,use_container_width=True)
            except Exception as e: add_notif(f"Erreur SQL : {e}","error"); st.rerun()

    st.markdown('<p class="sql-sec-title" style="margin-top:1rem">Installation ODBC</p>', unsafe_allow_html=True)
    st.markdown('<div class="sql-query-box" style="font-size:11px">pip install pyodbc<br><br># Ubuntu / App Service :<br>ACCEPT_EULA=Y apt-get install -y msodbcsql18</div>', unsafe_allow_html=True)

