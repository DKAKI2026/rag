def charger_logo() -> str:
    for ext in ["png", "jpg", "jpeg", "PNG", "JPG"]:
        chemin = f"photos/logo.{ext}"
        if os.path.exists(chemin):
            with open(chemin, "rb") as f:
                data = base64.b64encode(f.read()).decode()
            return f"data:image/{ext.lower()};base64,{data}"
    return None

